# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
*.lcov

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eslint
.eslintcache

# prisma (local scratch / old migrate artifacts if any)
prisma/*.db
prisma/*.db-journal

# Playwright / e2e (if added later)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Sentry CLI local config
.sentryclirc
