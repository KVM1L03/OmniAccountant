# Prisma / Next.js — copy to `.env.local` before running `npx prisma db push`.
#
# `invoice_app` is a dedicated database on the shared Postgres container
# (distinct from Temporal's `temporal` DB and Langfuse's `langfuse` DB).
# Prisma 7 creates it automatically on first `db push` using the
# `createdb` grant that the `temporal` user has. No manual SQL required.
DATABASE_URL="postgresql://temporal:temporal@localhost:5432/invoice_app"

# Backend API Gateway URL — used by Server Actions for telemetry data.
API_GATEWAY_URL="http://localhost:8000"
